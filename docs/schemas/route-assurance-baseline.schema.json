{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/v-k-tsalikidis/security-headers-auditor/blob/main/docs/schemas/route-assurance-baseline.schema.json",
  "title": "Security Headers Auditor Route Assurance Baseline",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact",
    "methodology_version",
    "mapping_set_version",
    "manifest",
    "routes"
  ],
  "properties": {
    "schema_version": { "const": "1.0" },
    "artifact": { "const": "security-headers-auditor.route-assurance-baseline" },
    "methodology_version": { "const": "0.5.0" },
    "mapping_set_version": { "const": "2026.07.2" },
    "manifest": { "$ref": "#/$defs/manifest" },
    "routes": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/route" }
    }
  },
  "$defs": {
    "manifest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "name", "origin", "routes"],
      "properties": {
        "schema_version": { "const": "1.0" },
        "name": { "type": "string", "minLength": 1, "maxLength": 120 },
        "origin": { "type": "string", "minLength": 1 },
        "routes": {
          "type": "array",
          "minItems": 2,
          "maxItems": 25,
          "items": { "$ref": "#/$defs/manifestRoute" }
        }
      }
    },
    "manifestRoute": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "path", "profile"],
      "properties": {
        "id": { "type": "string", "minLength": 1, "maxLength": 120 },
        "path": { "type": "string", "minLength": 1 },
        "profile": { "enum": ["app", "api", "brochure"] }
      }
    },
    "route": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "declared_profile", "score", "scored_controls"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "declared_profile": { "enum": ["app", "api", "brochure"] },
        "score": { "type": "integer", "minimum": 0, "maximum": 100 },
        "scored_controls": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": { "$ref": "#/$defs/control" }
        }
      }
    },
    "control": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "severity", "points", "max_points"],
      "properties": {
        "status": {
          "enum": ["pass", "info", "observed", "not_applicable", "review", "warning", "missing", "error"]
        },
        "severity": { "enum": ["info", "low", "medium", "high"] },
        "points": { "type": "number", "minimum": 0 },
        "max_points": { "type": "number", "minimum": 0 }
      }
    }
  }
}
